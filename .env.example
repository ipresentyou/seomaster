##
## Lavarell .env.example
##

APP_NAME=SEOmaster
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://deine-domain.de

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lavarell
DB_USERNAME=lavarell_user
DB_PASSWORD=sicheres_passwort

# ──────────────────────────────────────────────────────────────────────────────
# PayPal Setup-Anleitung:
#
# SCHRITT 1: developer.paypal.com → Apps & Credentials → App erstellen
#   → Client ID + Secret kopieren (sandbox & live getrennt)
#
# SCHRITT 2: Webhook einrichten
#   → Webhooks → Add Webhook
#   → URL: https://deine-domain.de/webhooks/paypal
#   → Events aktivieren:
#      BILLING.SUBSCRIPTION.ACTIVATED, CANCELLED, EXPIRED, SUSPENDED,
#      BILLING.SUBSCRIPTION.PAYMENT.FAILED,
#      PAYMENT.SALE.COMPLETED, PAYMENT.SALE.REFUNDED
#   → Webhook ID kopieren → PAYPAL_WEBHOOK_ID
#
# SCHRITT 3: Billing Plans anlegen (NACH php artisan db:seed --class=SubscriptionPlanSeeder)
#   → Subscriptions → Plans → Create Plan
#   → Für Starter/Pro/Agency je 1x monthly + 1x yearly Plan erstellen
#   → Plan-IDs in PAYPAL_PLAN_* Variablen eintragen
#   → Seeder erneut ausführen: php artisan db:seed --class=SubscriptionPlanSeeder
# ──────────────────────────────────────────────────────────────────────────────

PAYPAL_MODE=sandbox

PAYPAL_SANDBOX_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_SANDBOX_CLIENT_SECRET=EGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_APP_ID=

PAYPAL_WEBHOOK_ID=
PAYPAL_PRODUCT_ID=
PAYPAL_CURRENCY=EUR
PAYPAL_INVOICE_PREFIX=LAVARELL-

PAYPAL_PLAN_STARTER_MONTHLY=
PAYPAL_PLAN_STARTER_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
PAYPAL_PLAN_AGENCY_MONTHLY=
PAYPAL_PLAN_AGENCY_YEARLY=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@deine-domain.de
MAIL_FROM_NAME=Lavarell

# Cache/Session/Queue
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Filament
FILAMENT_ADMIN_EMAIL=admin@deine-domain.de
